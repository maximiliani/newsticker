{
    "environment": [
        {
            "type": "env",
            "key": "EXAMPLE_KEY",
            "value": "example_value"
        }
    ],
    "setup": {
        "macos": [
            "echo \\\"Setup ran successfully with $EXAMPLE_KEY!\\\" > /tmp/air-setup-test.txt"
        ]
    },
    "cleanup": {
        "macos": [
            "rm -f /tmp/air-setup-test.txt"
        ]
    }
}
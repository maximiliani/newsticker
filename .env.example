# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Instagram / Facebook
INSTAGRAM_CLIENT_ID=your-facebook-app-client-id
INSTAGRAM_CLIENT_SECRET=your-facebook-app-client-secret
NEXT_PUBLIC_INSTAGRAM_CLIENT_ID=your-facebook-app-client-id

# Internal shared secret for privileged API routes (optional but recommended)
INTERNAL_ADMIN_SECRET=replace-with-a-strong-random-secret

# Cron configuration (used by pg_cron via Vault)
# Store these values in Supabase Vault using upsert_vault_secret for production
# Example names expected by the migration: CRON_APP_BASE_URL, INTERNAL_ADMIN_SECRET
CRON_APP_BASE_URL=http://localhost:3000

NEXT_PUBLIC_REFRESH_EVERY_MINUTES=15
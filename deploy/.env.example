# === DB SETTINGS ===
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_HOST=db

# === JWT SETTINGS ===
# Use a 64-character hex string.
JWT_SECRET=replace-this-with-a-64-character-hex-string
ANON_KEY=replace-this-with-the-generated-anon-key
SERVICE_ROLE_KEY=replace-this-with-the-generated-service-role-key

# === KIOSK MODE ===
NEXT_PUBLIC_KIOSK_MODE=true
HOST_AGENT_URL=http://localhost:9876
HOST_AGENT_SECRET=replace-this-with-host-agent-secret

# === APP PUBLIC VARIABLES ===
# For local deployment, this points to Kong
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}

# === APP SERVER VARIABLES ===
SUPABASE_URL=http://kong:8000
SUPABASE_ANON_KEY=${ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}
INTERNAL_ADMIN_SECRET=replace-with-a-strong-random-secret

# === CRON CONFIGURATION ===
# Used by pg_cron inside the database to call the app
CRON_APP_BASE_URL=http://app:3000
NEXT_PUBLIC_REFRESH_EVERY_MINUTES=15

# === INSTAGRAM / FACEBOOK ===
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
NEXT_PUBLIC_INSTAGRAM_CLIENT_ID=
